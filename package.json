{
  "name": "archiductor",
  "version": "0.0.1",
  "private": true,
  "description": "Archiductor — AI-augmented multi-language enterprise modeling tool. Monorepo voor archimate-js en toekomstige packages (uml-js, cross-language-linking) plus de Archiductor-applicatie wanneer die uit archiductus.nl gesplitst wordt.",
  "license": "MIT",
  "author": "Pieter de Brabander",
  "homepage": "https://github.com/ptrdbrbndr/archiductor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ptrdbrbndr/archiductor.git"
  },
  "bugs": {
    "url": "https://github.com/ptrdbrbndr/archiductor/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
