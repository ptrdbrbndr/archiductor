{
  "name": "archimate-mcp",
  "version": "0.1.0",
  "description": "MCP server for ArchiMate model read/write via Claude API",
  "license": "MIT",
  "author": "Pieter de Brabander",
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": "./dist/server.js"
  },
  "scripts": {
