{
  "name": "archimate-mcp",
  "version": "0.0.1",
  "description": "HTTP/SSE MCP server exposing ArchiMate models via 15 tools to the Claude API",
  "license": "MIT",
  "author": "Pieter de Brabander",
  "homepage": "https://github.com/ptrdbrbndr/archiductor/tree/main/packages/archimate-mcp",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ptrdbrbndr/archiductor.git",
    "directory": "packages/archimate-mcp"
  },
  "bugs": {
    "url": "https://github.com/ptrdbrbndr/archiductor/issues"
  },
  "type": "module",
  "main": "./dist/server.js",
  "exports": {
    ".": {
      "import": "./dist/server.js"
    }
